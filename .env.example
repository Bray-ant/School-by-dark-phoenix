# Database (MySQL)
DATABASE_URL=mysql://user:password@host:port/database

# Session signing (generate a strong random string, e.g. openssl rand -base64 32)
SESSION_SECRET=your_session_secret

# Optional: NVIDIA NIM API for AI responses (primary provider)
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# Optional: Google AI Studio (Gemini) for AI responses (fallback if NVIDIA is not configured)
GOOGLE_AI_KEY=your_google_ai_key
GOOGLE_AI_URL=https://generativelanguage.googleapis.com/v1beta/openai
GOOGLE_AI_MODEL=gemini-2.0-flash

# Optional: Kimi API key for AI responses (fallback if neither NVIDIA nor Google AI is configured)
KIMI_API_KEY=your_api_key
KIMI_OPEN_URL=https://open.kimi.com

# Optional: SMTP for sending OTP/password-reset emails. Without these,
# OTPs/tokens are returned directly in API responses for local dev instead.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_EMAIL=your_email@gmail.com
