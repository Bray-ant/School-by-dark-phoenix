# Database (MySQL)
DATABASE_URL=mysql://user:password@host:port/database

# Session signing (generate a strong random string, e.g. openssl rand -base64 32)
SESSION_SECRET=your_session_secret

# Optional: Kimi API key for enhanced AI responses (no OAuth required)
KIMI_API_KEY=your_api_key
KIMI_OPEN_URL=https://open.kimi.com

# Optional: SMTP for sending OTP/password-reset emails. Without these,
# OTPs/tokens are returned directly in API responses for local dev instead.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_EMAIL=your_email@gmail.com
